# ── Microsoft Graph ──────────────────────────────────────────────────────────
# Azure App Registration with these API permissions:
#   Application.Read.All, Application.ReadWrite.All (or ServicePrincipalEndpoint.ReadWrite.All)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-app-registration-client-id
AZURE_CLIENT_SECRET=your-client-secret

# ── AI Providers (fill in at least one) ──────────────────────────────────────
# System auto-switches: Groq → Gemini → Mistral
# Leave blank to skip a provider.
GROQ_API_KEY=your-groq-key
GEMINI_API_KEY=your-gemini-key
MISTRAL_API_KEY=your-mistral-key

# ── App Settings ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000
# Random 32-character string for internal signing
SECRET_KEY=change-me-to-a-random-32-char-string
# Set to true to skip all PATCH calls to Graph (safe testing mode)
DRY_RUN=false
